<UserControl
    x:Class="NirZonshine.NINA.HorizonStudio.Views.HorizonManagementCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NirZonshine.NINA.HorizonStudio"
    xmlns:views="clr-namespace:NirZonshine.NINA.HorizonStudio.Views">

    <UserControl.Resources>
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Border x:Name="glow" Background="White" Opacity="0" CornerRadius="6" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="glow" Property="Opacity" Value="0.15" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#353540" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical">
        
        <!-- Section 1: Mount Jogging & Slewing -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Mount Jogging &amp; Slewing" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                
                <!-- 5x5 Directional Jogging Grid -->
                <Grid Width="180" Height="150" HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: Double-Arrow Diagonals & North -->
                    <Button Grid.Row="0" Grid.Column="0" Content="↖↖" Command="{Binding DoubleJogNorthWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt++, Az--" FontSize="9" />
                    <Button Grid.Row="0" Grid.Column="1" Content="▲▲◀" Command="{Binding JogN2W1Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt++, Az-" FontSize="9" />
                    <Button Grid.Row="0" Grid.Column="2" Content="▲▲" Command="{Binding DoubleJogNorthCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Alt++" FontSize="9" />
                    <Button Grid.Row="0" Grid.Column="3" Content="▲▲▶" Command="{Binding JogN2E1Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt++, Az+" FontSize="9" />
                    <Button Grid.Row="0" Grid.Column="4" Content="↗↗" Command="{Binding DoubleJogNorthEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt++, Az++" FontSize="9" />

                    <!-- Row 1: Single-Arrow Diagonals & North -->
                    <Button Grid.Row="1" Grid.Column="0" Content="▼◀◀" Command="{Binding JogN1W2Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az--" FontSize="9" />
                    <Button Grid.Row="1" Grid.Column="1" Content="↖" Command="{Binding JogNorthWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az-" />
                    <Button Grid.Row="1" Grid.Column="2" Content="▲" Command="{Binding JogNorthCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Alt+" />
                    <Button Grid.Row="1" Grid.Column="3" Content="↗" Command="{Binding JogNorthEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az+" />
                    <Button Grid.Row="1" Grid.Column="4" Content="▼▶▶" Command="{Binding JogN1E2Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az++" FontSize="9" />

                    <!-- Row 2: Double/Single West, Home, Single/Double East -->
                    <Button Grid.Row="2" Grid.Column="0" Content="◀◀" Command="{Binding DoubleJogWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Az--" FontSize="9" />
                    <Button Grid.Row="2" Grid.Column="1" Content="◀" Command="{Binding JogWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Az-" />
                    <Button Grid.Row="2" Grid.Column="2" Content="⌂" Command="{Binding HomeMountCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2563EB" ToolTip="Home Mount" FontSize="14" />
                    <Button Grid.Row="2" Grid.Column="3" Content="▶" Command="{Binding JogEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Az+" />
                    <Button Grid.Row="2" Grid.Column="4" Content="▶▶" Command="{Binding DoubleJogEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Az++" FontSize="9" />

                    <!-- Row 3: Single-Arrow Diagonals & South -->
                    <Button Grid.Row="3" Grid.Column="0" Content="▲◀◀" Command="{Binding JogS1W2Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az--" FontSize="9" />
                    <Button Grid.Row="3" Grid.Column="1" Content="↙" Command="{Binding JogSouthWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az-" />
                    <Button Grid.Row="3" Grid.Column="2" Content="▼" Command="{Binding JogSouthCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Alt-" />
                    <Button Grid.Row="3" Grid.Column="3" Content="↘" Command="{Binding JogSouthEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az+" />
                    <Button Grid.Row="3" Grid.Column="4" Content="▲▶▶" Command="{Binding JogS1E2Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az++" FontSize="9" />

                    <!-- Row 4: Double-Arrow Diagonals & South -->
                    <Button Grid.Row="4" Grid.Column="0" Content="↙↙" Command="{Binding DoubleJogSouthWestCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt--, Az--" FontSize="9" />
                    <Button Grid.Row="4" Grid.Column="1" Content="▼▼◀" Command="{Binding JogS2W1Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt--, Az-" FontSize="9" />
                    <Button Grid.Row="4" Grid.Column="2" Content="▼▼" Command="{Binding DoubleJogSouthCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Alt--" FontSize="9" />
                    <Button Grid.Row="4" Grid.Column="3" Content="▼▼▶" Command="{Binding JogS2E1Command}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt--, Az+" FontSize="9" />
                    <Button Grid.Row="4" Grid.Column="4" Content="↘↘" Command="{Binding DoubleJogSouthEastCommand}" IsEnabled="{Binding Radar.CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Alt--, Az++" FontSize="9" />
                </Grid>

                <!-- Azimuth Slewing & Emergency Stop (Slew CCW, Stop, Slew CW) -->
                <Grid Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="◀ Slew CCW" Command="{Binding SlewCCWCommand}" IsEnabled="{Binding Radar.CanVerifyPoints}" Style="{StaticResource ActionBtnStyle}" Background="#4F46E5" Height="28" ToolTip="Slew Counter-Clockwise (Decreasing Azimuth)" FontSize="10.5" />
                    <Button Grid.Column="1" Command="{Binding StopMountCommand}" IsEnabled="{Binding IsMountConnected}" Style="{StaticResource ActionBtnStyle}" Background="#EF4444" Width="90" Height="28" Margin="4,0" ToolTip="EMERGENCY JOG SLEW STOP">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🛑" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <TextBlock Text="STOP" FontSize="10.5" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Content="Slew CW ▶" Command="{Binding SlewCWCommand}" IsEnabled="{Binding Radar.CanVerifyPoints}" Style="{StaticResource ActionBtnStyle}" Background="#4F46E5" Height="28" ToolTip="Slew Clockwise (Increasing Azimuth)" FontSize="10.5" />
                </Grid>

                <!-- Combined Step Sizes (Jog Alt, Jog Az, Verification Step) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="↕ Jog Alt (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding StepSizeAlt, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock Text="↔ Jog Az (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding StepSizeAz, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4,0,0,0">
                        <TextBlock Text="🔍 Verif. Step" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Radar.VerificationStepSizes}" SelectedItem="{Binding Radar.VerificationStepSize}" Height="24" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Section 2: Sync Landmarks -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <!-- Header -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Sync Landmarks" FontSize="12" FontWeight="Bold" Foreground="#FFD946EF" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Command="{Binding AddLandmarkCommand}" Content="➕ Add" Height="18" Background="#8B5CF6" Foreground="White" FontSize="9" Padding="6,0" Margin="0,0,4,0" Cursor="Hand" Style="{StaticResource ActionBtnStyle}" ToolTip="Add current mount coordinates as a sync landmark" />
                    <Button Grid.Column="2" Command="{Binding ClearAllLandmarksCommand}" Content="🗑️ Clear All" Height="18" Background="#EF4444" Foreground="White" FontSize="9" Padding="6,0" Cursor="Hand" ToolTip="Clear all landmarks">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasLandmarks}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Landmark List -->
                <ListBox ItemsSource="{Binding SyncLandmarks}" SelectedItem="{Binding SelectedLandmark}" MaxHeight="100" Background="#0c0c0e" BorderThickness="1" BorderBrush="#2D2D35" Margin="0,2,0,4" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="6,4" />
                            <Setter Property="Foreground" Value="White" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#2D1B4E" />
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1A1A24" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFD946EF" VerticalAlignment="Center" FontSize="10.5" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="  Az: " FontSize="9.5" Foreground="DarkGray" />
                                    <TextBlock Text="{Binding Azimuth, StringFormat={}{0:F1}°}" FontSize="9.5" FontWeight="Bold" Foreground="LightGray" Margin="0,0,6,0" />
                                    <TextBlock Text="Alt: " FontSize="9.5" Foreground="DarkGray" />
                                    <TextBlock Text="{Binding Altitude, StringFormat={}{0:F1}°}" FontSize="9.5" FontWeight="Bold" Foreground="LightGray" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Controls for Selected Landmark -->
                <StackPanel Orientation="Vertical">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="✏️ Rename" Command="{Binding RenameLandmarkCommand}" Height="22" Background="#1E1B4B" Margin="0,0,2,0" FontSize="10" ToolTip="Rename selected landmark" />
                        <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="🔷 Slew" Command="{Binding SlewToLandmarkCommand}" Height="22" Background="#4F46E5" Margin="2,0,2,0" FontSize="10" ToolTip="Slew mount directly to this landmark" />
                        <Button Grid.Column="2" Style="{StaticResource ActionBtnStyle}" Content="❌ Delete" Command="{Binding DeleteLandmarkCommand}" Height="22" Background="#EF4444" Margin="2,0,0,0" FontSize="10" ToolTip="Remove selected landmark" />
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Section 3: Horizon Pin Placement -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Horizon Pin Placement" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ActionBtnStyle}" Content="Drop Horizon Pin" Command="{Binding DropPinCommand}" Height="36" IsEnabled="{Binding CanDropPin}" Background="#3B82F6" Margin="0,0,0,6" />
                    <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Remove Current Pin" Command="{Binding DeletePointCommand}" Height="28" Background="#6B7280" Margin="0,0,4,0" FontSize="11" ToolTip="Remove currently selected pin" />
                    <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Clear All Pins" Command="{Binding ClearPinsCommand}" Height="28" Background="#E11D48" Margin="4,0,0,0" FontSize="11" ToolTip="Remove all pins" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Section 4: Point Details & Verification Panel -->
        <Border CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="#2D2D35" Padding="8,6" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasActiveNode}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical">
                    <!-- Title: standard active node or sync node -->
                    <TextBlock FontSize="10" Foreground="Gray" Text="ACTIVE VERIFICATION NODE" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#FFD946EF" Text="ACTIVE SYNC LANDMARK" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="#FF818CF8" Text="PROFILE SYNC REFERENCE NODE" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <!-- Standard Index Panel -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Index: " FontSize="11" Foreground="DarkGray" />
                            <TextBlock Text="{Binding ActiveNodeIndex}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF" />
                            <TextBlock Text="  |  " FontSize="11" Foreground="DarkGray" />
                        </StackPanel>
                        
                        <!-- Special Sync Node Landmark Panel -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Landmark.IsLandmarkSelected}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="{Binding Landmark.SelectedLandmark.Name}" FontSize="11" FontWeight="Bold" Foreground="#FFD946EF" />
                            <TextBlock Text="  |  " FontSize="11" Foreground="DarkGray" />
                        </StackPanel>

                        <TextBlock Text="Az: " FontSize="11" Foreground="DarkGray" />
                        <TextBlock Text="{Binding SyncRefNode.Azimuth, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ActiveNode.Azimuth, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="  Alt: " FontSize="11" Foreground="DarkGray" />
                        <TextBlock Text="{Binding SyncRefNode.Altitude, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding ActiveNode.Altitude, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Standard Card Buttons (Prepare Sync, Delete Node) -->
                    <StackPanel Orientation="Vertical">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Prepare Sync" Command="{Binding PrepareSyncCommand}" Height="24" Background="#8B5CF6" Margin="0,0,4,0" FontSize="10.5" ToolTip="Prepare 3D Tilt Sync" />
                            <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Delete Node" Command="{Binding DeletePointCommand}" Height="24" Background="#EF4444" Margin="4,0,0,0" FontSize="10.5" ToolTip="Remove node" />
                        </Grid>
                    </StackPanel>

                    <!-- Sync-Prep Card Buttons (Confirm Sync, Cancel Sync) -->
                    <StackPanel Orientation="Vertical">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <!-- Warning/Instruction Banner -->
                        <Border CornerRadius="4" Background="{Binding Landmark.SyncBannerBackground}" BorderThickness="1" BorderBrush="{Binding Landmark.SyncBannerBorderBrush}" Padding="6,4" Margin="0,6,0,0">
                            <TextBlock Text="{Binding Landmark.SyncInstructionText}" FontSize="9.5" FontWeight="SemiBold" Foreground="{Binding Landmark.SyncBannerForeground}" TextWrapping="Wrap" />
                        </Border>
                        
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Confirm Sync" Command="{Binding ConfirmSyncCommand}" IsEnabled="{Binding Landmark.CanConfirmSync}" Height="24" Background="#10B981" Margin="0,0,4,0" FontSize="10.5" ToolTip="Confirm 3D Tilt Correction" />
                            <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Cancel" Command="{Binding CancelSyncCommand}" Height="24" Background="#6B7280" Margin="4,0,0,0" FontSize="10.5" ToolTip="Abort the synchronization process" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0" />
            </Grid>
        </Border>

        <!-- Section 5: Profile Storage -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Profile Storage" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Save Horizon Profile" Command="{Binding SaveHorizonCommand}" Height="34" Background="#F59E0B" Margin="0,0,4,0" ToolTip="Save pins to .hrz" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Load Horizon Profile" Command="{Binding LoadHorizonCommand}" Height="34" Background="#10B981" Margin="4,0,0,0" ToolTip="Load .hrz file" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Section 6: Hardware & Safety Settings -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,8">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Hardware &amp; Safety Settings" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                
                <Grid Margin="0,0,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <!-- Camera Rotation & Offset -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,6" ToolTip="Counter-rotates webcam for EQ mounts.">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                            <TextBlock Text="🔄 EQ Auto-Rotate" FontSize="9" Foreground="DarkGray" Margin="0,0,4,0" VerticalAlignment="Center" />
                            <CheckBox IsChecked="{Binding Webcam.IsCounterRotationEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                        <Slider Value="{Binding Webcam.CameraRotationOffset, UpdateSourceTrigger=PropertyChanged}" Minimum="-180" Maximum="180" TickFrequency="1" IsSnapToTickEnabled="True" Height="20" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Webcam.CameraRotationOffset, StringFormat=Offset: {0}°}" FontSize="9" Foreground="DarkGray" HorizontalAlignment="Center" />
                    </StackPanel>

                    <!-- Field Rotation Angle Readout -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="6,0,0,6" ToolTip="Calculated Parallactic Angle">
                        <TextBlock Text="Rot. Angle" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <Border CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Height="24" Padding="6,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Webcam.WebcamImageRotationAngle, StringFormat={}{0:F1}°}" FontSize="10" FontWeight="Bold" Foreground="#FF00F3FF" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <!-- Safety exclusions checklist -->
                    <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4" ToolTip="Proximity Lockout">
                            <TextBlock Text="Solar Safety" Foreground="#FBBF24" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <CheckBox IsChecked="{Binding EnableSolarSafety, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4" ToolTip="Proximity Lockout">
                            <TextBlock Text="Zenith Lock" Foreground="#FCA5A5" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <CheckBox IsChecked="{Binding EnableZenithSafety, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4" ToolTip="Lock Altitude">
                            <TextBlock Text="Horiz. Lock" Foreground="#818CF8" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <CheckBox IsChecked="{Binding HorizonLockEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4" ToolTip="Drift Countering">
                            <TextBlock Text="🎯 Exact Pos." Foreground="#34D399" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <CheckBox IsChecked="{Binding IsExactPositionEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4" ToolTip="Radar Canvas Overlay">
                            <TextBlock Text="📡 HUD Overlay" Foreground="#FFA07A" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                            <CheckBox IsChecked="{Binding IsRadarOverlayEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                        </StackPanel>
                    </WrapPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Section 7: 3D Polar Alignment Sync -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="3D Polar Alignment Sync" FontSize="12" FontWeight="Bold" Foreground="#FF38BDF8" Margin="0,0,0,8" />
                
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="↕ Alt Offset (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding PolarAltOffset, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                        <TextBlock Text="↔ Az Offset (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding PolarAzOffset, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                </Grid>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="⚡ Auto-Detect" Command="{Binding AutoDetectPolarOffsetCommand}" Height="30" Background="#4F46E5" Margin="0,0,4,0" ToolTip="Scan latest N.I.N.A. log for polar alignment errors" FontSize="10.5" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Apply Polar Sync" Command="{Binding ApplyPolarSyncCommand}" Height="30" Background="#10B981" Margin="4,0,0,0" ToolTip="Apply 3D Polar Alignment warp to profile" FontSize="10.5" />
                </Grid>
            </StackPanel>
        </Border>
        
    </StackPanel>
</UserControl>
