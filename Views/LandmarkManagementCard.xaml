<UserControl
    x:Class="NirZonshine.NINA.HorizonStudio.Views.LandmarkManagementCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NirZonshine.NINA.HorizonStudio"
    xmlns:views="clr-namespace:NirZonshine.NINA.HorizonStudio.Views">

    <UserControl.Resources>
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Border x:Name="glow" Background="White" Opacity="0" CornerRadius="6" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="glow" Property="Opacity" Value="0.15" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#353540" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Sync Landmarks Management Card -->
    <Border CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="#2D2D35" Padding="8,6" Margin="0,8,0,0">
        <StackPanel Orientation="Vertical">
            <!-- Card Header -->
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="🔷 SYNC LANDMARKS" FontSize="10" FontWeight="SemiBold" Foreground="#FFD946EF" VerticalAlignment="Center" />
                <Button Grid.Column="1" Command="{Binding Parent.AddLandmarkCommand}" Content="➕ Add" Height="18" Background="#8B5CF6" Foreground="White" FontSize="9" Padding="6,0" Margin="0,0,4,0" Cursor="Hand" Style="{StaticResource ActionBtnStyle}" ToolTip="Add current mount coordinates as a sync landmark" />
                <Button Grid.Column="2" Command="{Binding Parent.ClearAllLandmarksCommand}" Content="🗑️ Clear All" Height="18" Background="#EF4444" Foreground="White" FontSize="9" Padding="6,0" Cursor="Hand" ToolTip="Clear all landmarks">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasLandmarks}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Landmark List -->
            <ListBox ItemsSource="{Binding SyncLandmarks}" SelectedItem="{Binding SelectedLandmark}" MaxHeight="120" Background="#0c0c0e" BorderThickness="1" BorderBrush="#2D2D35" Margin="0,2,0,4" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="6,4" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2D1B4E" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A1A24" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold" Foreground="#FFD946EF" VerticalAlignment="Center" FontSize="10.5" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="  Az: " FontSize="9.5" Foreground="DarkGray" />
                                <TextBlock Text="{Binding Azimuth, StringFormat={}{0:F1}°}" FontSize="9.5" FontWeight="Bold" Foreground="LightGray" Margin="0,0,6,0" />
                                <TextBlock Text="Alt: " FontSize="9.5" Foreground="DarkGray" />
                                <TextBlock Text="{Binding Altitude, StringFormat={}{0:F1}°}" FontSize="9.5" FontWeight="Bold" Foreground="LightGray" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Controls for Selected Landmark -->
            <StackPanel Orientation="Vertical">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLandmarkSelected}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="✏️ Rename" Command="{Binding Parent.RenameLandmarkCommand}" Height="22" Background="#1E1B4B" Margin="0,0,2,0" FontSize="10" ToolTip="Rename the selected landmark" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="🔷 Slew" Command="{Binding Parent.SlewToLandmarkCommand}" Height="22" Background="#4F46E5" Margin="2,0,2,0" FontSize="10" ToolTip="Slew mount directly to this landmark" />
                    <Button Grid.Column="2" Style="{StaticResource ActionBtnStyle}" Content="❌ Delete" Command="{Binding Parent.DeleteLandmarkCommand}" Height="22" Background="#EF4444" Margin="2,0,0,0" FontSize="10" ToolTip="Remove the selected landmark" />
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
