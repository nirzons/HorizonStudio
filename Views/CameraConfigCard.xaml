<UserControl
    x:Class="NirZonshine.NINA.HorizonStudio.Views.CameraConfigCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NirZonshine.NINA.HorizonStudio"
    xmlns:views="clr-namespace:NirZonshine.NINA.HorizonStudio.Views">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Grid>
                                <Border x:Name="glow" Background="White" Opacity="0" CornerRadius="6" />
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="glow" Property="Opacity" Value="0.15" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#353540" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel Orientation="Vertical">
        <!-- Row 0: Visual Feed Source Selector -->
        <Border CornerRadius="8" Background="#14141A" BorderThickness="1" BorderBrush="#2D2D35" Padding="4" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                
                <!-- Webcam Selector Button -->
                <Button Grid.Column="0" Content="📷 USB Webcam" Height="28" Margin="2" Cursor="Hand" BorderThickness="0"
                        Command="{Binding SelectVisualFeedSourceCommand}" CommandParameter="Webcam">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="Gray" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Webcam.IsWebcamFeedSelected}" Value="True">
                                    <Setter Property="Background" Value="#3B82F6" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Main Camera Selector Button -->
                <Button Grid.Column="1" Content="🔭 Main Camera" Height="28" Margin="2" Cursor="Hand" BorderThickness="0"
                        Command="{Binding SelectVisualFeedSourceCommand}" CommandParameter="MainCamera">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="Gray" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Webcam.IsMainCameraFeedSelected}" Value="True">
                                    <Setter Property="Background" Value="#3B82F6" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.85" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- Row 1: UVC Webcam Configuration (Webcam Mode) -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Webcam.IsWebcamFeedSelected}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Vertical">
                <!-- Webcam Header with Dot Status Indicator -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="UVC Webcam Configuration" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" VerticalAlignment="Center" />
                    
                    <!-- Webcam State Status Badge -->
                    <Border Grid.Column="1" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="6,2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="{Binding Webcam.WebcamStatusIndicatorColor}" Margin="0,0,5,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Webcam.CurrentWebcamState}" FontSize="9.5" FontWeight="SemiBold" Foreground="{Binding Webcam.WebcamStatusIndicatorColor}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Camera Chooser Dropdown and Refresh Button -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" ItemsSource="{Binding Webcam.AvailableWebcams}" SelectedItem="{Binding Webcam.SelectedWebcam}" Height="28" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" VerticalContentAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" Foreground="White" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Grid.Column="1" Command="{Binding RefreshWebcamsCommand}" Content="🔄" Width="28" Height="28" Margin="6,0,0,0" ToolTip="Refresh available webcams list" Background="#2A2A35" Foreground="White" FontWeight="Bold" Cursor="Hand" />
                </Grid>

                <!-- Start / Stop Stream Actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start Video Feed" Command="{Binding StartWebcamCommand}" Height="28" Background="#6366F1" Margin="0,0,4,0" FontSize="11" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Stop Video Feed" Command="{Binding StopWebcamCommand}" Height="28" Background="#EF4444" Margin="4,0,0,0" FontSize="11" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 1: Main Camera Configuration (Main Camera Mode) -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Webcam.IsMainCameraFeedSelected}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Vertical">
                <!-- Camera Header with Dot Status Indicator -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Main Camera Configuration" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" VerticalAlignment="Center" />
                    
                    <!-- Main Camera State Status Badge -->
                    <Border Grid.Column="1" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="6,2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Margin="0,0,5,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#9E9E9E" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Camera.IsMainCameraActive}" Value="True">
                                                <Setter Property="Fill" Value="#22C55E" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCameraConnected}" Value="False" />
                                                    <Condition Binding="{Binding Camera.IsMainCameraActive}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Fill" Value="#EF4444" />
                                            </MultiDataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCameraConnected}" Value="True" />
                                                    <Condition Binding="{Binding Camera.IsMainCameraActive}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Fill" Value="#F59E0B" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock FontSize="9.5" FontWeight="SemiBold" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Idle" />
                                        <Setter Property="Foreground" Value="#F59E0B" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Camera.IsMainCameraActive}" Value="True">
                                                <Setter Property="Text" Value="Streaming" />
                                                <Setter Property="Foreground" Value="#22C55E" />
                                            </DataTrigger>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsCameraConnected}" Value="False" />
                                                    <Condition Binding="{Binding Camera.IsMainCameraActive}" Value="False" />
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Text" Value="Disconnected" />
                                                <Setter Property="Foreground" Value="#EF4444" />
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Shutter Safety Warning Banner -->
                <Border CornerRadius="4" Background="#3D2A14" BorderThickness="1" BorderBrush="#F59E0B" Padding="8,6" Margin="0,0,0,8">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Camera.HasMechanicalShutter}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" Foreground="#FBBF24" FontSize="12" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="MECHANICAL SHUTTER DETECTED - Continuous looping exposures may cause excessive shutter wear. Proceed with caution." Foreground="#FBBF24" FontSize="9.5" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Camera Parameters -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                        <TextBlock Text="Exposure (s)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding ExposureTime, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0">
                            <TextBox.Style>
                                <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Camera.IsAutoExposureEnabled}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4,0,4,0">
                        <TextBlock Text="Gain" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <TextBox Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4,0,0,0">
                        <TextBlock Text="Binning" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                        <ComboBox ItemsSource="{Binding Camera.AvailableBinningModes}" SelectedItem="{Binding Camera.SelectedBinning}" Height="24" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" VerticalContentAlignment="Center">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Auto Exposure & Target ADU -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="Auto-Exposure" FontSize="10" Foreground="White" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <CheckBox IsChecked="{Binding Camera.IsAutoExposureEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Camera.IsAutoExposureEnabled}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Target ADU: " FontSize="10" Foreground="DarkGray" VerticalAlignment="Center" Margin="0,0,4,0" />
                        <TextBox Text="{Binding Camera.TargetADU, UpdateSourceTrigger=PropertyChanged}" Width="70" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                    </StackPanel>
                </Grid>

                <!-- Start / Stop Exposure Actions -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start Exposure Feed" Command="{Binding StartMainCameraCommand}" IsEnabled="{Binding Camera.CanStartMainCamera}" Height="28" Background="#6366F1" Margin="0,0,4,0" FontSize="11" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Stop Exposure Feed" Command="{Binding StopMainCameraCommand}" IsEnabled="{Binding Camera.CanStopMainCamera}" Height="28" Background="#EF4444" Margin="4,0,0,0" FontSize="11" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 2: Webcam Co-Alignment Assistant -->
        <Border CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Webcam.IsWebcamFeedSelected}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Webcam Co-Alignment Assistant" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                
                <!-- Co-Alignment Instruction Tip -->
                <Border CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="8" Margin="0,0,0,8">
                    <TextBlock Text="Align the webcam feed with your primary telescope axis. Center a target in your main camera, click the same target in the webcam view, and save." FontSize="9.5" Foreground="DarkGray" TextWrapping="Wrap" />
                </Border>
                
                <!-- Co-Alignment Status Badge and Target Center readout -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Center Ratio: " FontSize="9.5" Foreground="Gray" />
                        <TextBlock Text="{Binding Webcam.AlignmentCenterX, StringFormat={}{0:F3}}" FontSize="9.5" FontWeight="SemiBold" Foreground="#FFF59E0B" />
                        <TextBlock Text=", " FontSize="9.5" Foreground="Gray" />
                        <TextBlock Text="{Binding Webcam.AlignmentCenterY, StringFormat={}{0:F3}}" FontSize="9.5" FontWeight="SemiBold" Foreground="#FFF59E0B" />
                    </StackPanel>
                    
                    <Border Grid.Column="1" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="6,2" VerticalAlignment="Center">
                        <TextBlock Text="ALIGNED" FontSize="8.5" FontWeight="Bold" Foreground="#22C55E" VerticalAlignment="Center" Visibility="{Binding Webcam.IsCoAligned, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Border>
                </Grid>

                <!-- Co-Alignment Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start" Command="{Binding StartCoAlignmentCommand}" Height="28" Background="#8B5CF6" Margin="0,0,4,0" FontSize="11" ToolTip="Start Co-Alignment assistant" />
                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Save" Command="{Binding SaveCoAlignmentCommand}" IsEnabled="{Binding Webcam.IsCoAligning}" Height="28" Background="#22C55E" Margin="4,0,4,0" FontSize="11" ToolTip="Save co-alignment coordinate" />
                    <Button Grid.Column="2" Style="{StaticResource ActionBtnStyle}" Content="Reset" Command="{Binding ResetCoAlignmentCommand}" Height="28" Background="#E11D48" Margin="4,0,0,0" FontSize="11" ToolTip="Reset co-alignment to center" />
                </Grid>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
