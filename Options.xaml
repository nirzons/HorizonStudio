<ResourceDictionary
    x:Class="NirZonshine.NINA.HorizonStudio.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:local="clr-namespace:NirZonshine.NINA.HorizonStudio"
    xmlns:vm="clr-namespace:NirZonshine.NINA.HorizonStudio.ViewModels">

    <!-- Global HVM Options DataTemplate -->
    <DataTemplate x:Key="Horizon Studio_Options">
        <StackPanel Orientation="Vertical" Margin="10">
            <TextBlock Text="Horizon Studio Settings" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,10" />
            <TextBlock Text="No global configuration is required. All settings can be adjusted directly from the Horizon Studio panel in the Imaging screen." Foreground="#999" TextWrapping="Wrap" />
        </StackPanel>
    </DataTemplate>

    <!-- Main Dockable UI DataTemplate (Loaded in N.I.N.A Imaging Screen) -->
    <DataTemplate x:Key="NirZonshine.NINA.HorizonStudio.ViewModels.HorizonMapperDockableVM_Dockable">
        <DataTemplate.Resources>
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <local:RenderedImageSizeConverter x:Key="RenderedImageSizeConverter" />
            <local:RatioToCoordinateConverter x:Key="RatioToCoordinateConverter" />
        </DataTemplate.Resources>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. Header & Status Banner Row -->
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <Border CornerRadius="8" Background="{DynamicResource MahApps.Brushes.Subtle}" Padding="15" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{DynamicResource MahApps.Brushes.Accent}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="Horizon Studio" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                            <TextBlock Text="Trace terrestrial obstacles in daylight using visual guides to automatically generate custom N.I.N.A. horizon profiles." FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="{Binding StatusIndicatorColor}" Padding="8,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusIndicatorText}" FontWeight="Bold" Foreground="{Binding StatusIndicatorColor}" FontSize="11" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Zenith Proximity Locked Alert Banner -->
                <Border CornerRadius="4" Background="#3D1C1C" BorderThickness="1" BorderBrush="#EF4444" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsZenithSafetyAlert}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🛑" Foreground="#EF4444" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SafetyMessage}" Foreground="#FCA5A5" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Solar Proximity Locked Alert Banner -->
                <Border CornerRadius="4" Background="#3D2A14" BorderThickness="1" BorderBrush="#F59E0B" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSolarSafetyAlert}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SafetyMessage}" Foreground="#FBBF24" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Connection Failure Badges -->
                <Border CornerRadius="4" Background="#3A1A1A" BorderThickness="1" BorderBrush="#FF4C4C" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMountConnected}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" Foreground="#FF4C4C" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="MOUNT NOT CONNECTED - Connect a telescope mount to begin visual horizon mapping" Foreground="#FF8C8C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 2. Dual-Column Content Row -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" /> <!-- Image Feed & HUD View -->
                    <ColumnDefinition Width="1*" />   <!-- Action & Configuration Controls -->
                </Grid.ColumnDefinitions>

                <!-- Column 0: Camera Live View & Sky Dome Radar Tabs -->
                <TabControl Grid.Column="0" Margin="0,0,10,0" Background="#0f0f12" BorderThickness="1" BorderBrush="#2A2A30">
                    <!-- Tab 1: Live Webcam View -->
                    <TabItem Header="📷 Live Camera View">
                        <Border CornerRadius="0,0,8,8" Padding="10" Background="#0c0c0e">
                            <Grid>
                                <!-- Fallback screen if camera is disabled/loading -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWebcamActive}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <Path Data="M4,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4M4,6V18H20V6H4M11,7A3,3 0 0,1 14,10A3,3 0 0,1 11,13A3,3 0 0,1 8,10A3,3 0 0,1 11,7M18,8A1,1 0 0,1 19,9A1,1 0 0,1 18,10A1,1 0 0,1 17,9A1,1 0 0,1 18,8M5,16H19V17H5V16Z" 
                                          Fill="#3D3D45" Width="48" Height="48" HorizontalAlignment="Center" />
                                    <TextBlock Text="UVC Webcam Live Stream" FontSize="13" FontWeight="Bold" Foreground="DarkGray" Margin="0,10,0,2" HorizontalAlignment="Center" />
                                    <TextBlock Text="Active UVC webcam frames will display here." FontSize="10" Foreground="Gray" HorizontalAlignment="Center" />
                                </StackPanel>
                                <!-- Symmetric Circular Eyepiece Webcam Display Container (Auto-scaling inside a Viewbox) -->
                                <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Grid Width="540" Height="540">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="ClipToBounds" Value="True" />
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsWebcamActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsCoAligning}" Value="True">
                                                    <Setter Property="ClipToBounds" Value="False" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <!-- 1. The rotating webcam feed (Width/Height 600x600, rotating around the co-alignment center) -->
                                    <Grid Width="600" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Grid.RenderTransform>
                                            <TransformGroup>
                                                <TranslateTransform X="{Binding AlignmentTranslationX}" Y="{Binding AlignmentTranslationY}" />
                                                <RotateTransform CenterX="300" CenterY="300" Angle="{Binding WebcamImageRotationAngle}" />
                                            </TransformGroup>
                                        </Grid.RenderTransform>

                                        <!-- Video Stream Source (Stretched to fill the entire eyepiece area cleanly) -->
                                        <Image x:Name="WebcamImage" Source="{Binding LastFrame}" Stretch="UniformToFill" MouseLeftButtonDown="Image_MouseLeftButtonDown" Cursor="Cross" />

                                        <!-- Aspect-Ratio-Locked Overlays Grid -->
                                        <Grid x:Name="OverlayContainer" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                            <Grid.Width>
                                                <MultiBinding Converter="{StaticResource RenderedImageSizeConverter}" ConverterParameter="Width">
                                                    <Binding Path="ActualWidth" ElementName="WebcamImage" />
                                                    <Binding Path="ActualHeight" ElementName="WebcamImage" />
                                                    <Binding Path="LastFrame.PixelWidth" />
                                                    <Binding Path="LastFrame.PixelHeight" />
                                                </MultiBinding>
                                            </Grid.Width>
                                            <Grid.Height>
                                                <MultiBinding Converter="{StaticResource RenderedImageSizeConverter}" ConverterParameter="Height">
                                                    <Binding Path="ActualWidth" ElementName="WebcamImage" />
                                                    <Binding Path="ActualHeight" ElementName="WebcamImage" />
                                                    <Binding Path="LastFrame.PixelWidth" />
                                                    <Binding Path="LastFrame.PixelHeight" />
                                                </MultiBinding>
                                            </Grid.Height>

                                            <!-- Concentric geometric center target HUD (Premium Cyan #FF00F3FF) -->
                                            <Grid IsHitTestVisible="False" Opacity="0.65">
                                                <Ellipse Width="240" Height="240" Stroke="#8000F3FF" StrokeThickness="0.8" StrokeDashArray="4,4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="110" Height="110" Stroke="#FF00F3FF" StrokeThickness="1.5" StrokeDashArray="2,2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="10" Height="10" Fill="#FF00F3FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Rectangle Width="1" Fill="#8000F3FF" StrokeDashArray="3,3" VerticalAlignment="Stretch" HorizontalAlignment="Center" Margin="0,10" />
                                                <Rectangle Height="1" Fill="#8000F3FF" StrokeDashArray="3,3" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,0" />
                                            </Grid>

                                            <!-- Dynamic Co-Alignment Target Reticle (Premium Orange #FFF59E0B) -->
                                            <Canvas IsHitTestVisible="False">
                                                <Canvas.Style>
                                                    <Style TargetType="Canvas">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCoAligned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsCoAligning}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Canvas.Style>
                                                <Grid Width="60" Height="60" Margin="-30,-30,0,0">
                                                    <Canvas.Left>
                                                        <MultiBinding Converter="{StaticResource RatioToCoordinateConverter}">
                                                            <Binding Path="AlignmentCenterX" />
                                                            <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        </MultiBinding>
                                                    </Canvas.Left>
                                                    <Canvas.Top>
                                                        <MultiBinding Converter="{StaticResource RatioToCoordinateConverter}">
                                                            <Binding Path="AlignmentCenterY" />
                                                            <Binding Path="ActualHeight" RelativeSource="{RelativeSource AncestorType=Canvas}" />
                                                        </MultiBinding>
                                                    </Canvas.Top>
                                                    <Ellipse Width="40" Height="40" Stroke="#FFF59E0B" StrokeThickness="1.5" StrokeDashArray="2,2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Ellipse Width="16" Height="16" Stroke="#FFF59E0B" StrokeThickness="1.0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Ellipse Width="6" Height="6" Fill="#FFF59E0B" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    <Line X1="0" Y1="30" X2="60" Y2="30" Stroke="#FFF59E0B" StrokeThickness="1.0" StrokeDashArray="3,3" />
                                                    <Line X1="30" Y1="0" X2="30" Y2="60" Stroke="#FFF59E0B" StrokeThickness="1.0" StrokeDashArray="3,3" />
                                                </Grid>
                                            </Canvas>
                                        </Grid>
                                    </Grid>

                                    <!-- 2. The stationary Donut Mask Overlay (Centering a circular transparent eyepiece cutout of radius 220) -->
                                    <Path Fill="#0c0c0e" IsHitTestVisible="False">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCoAligning}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                        <Path.Data>
                                            <CombinedGeometry GeometryCombineMode="Exclude">
                                                <CombinedGeometry.Geometry1>
                                                    <RectangleGeometry Rect="-100,-100,740,740" />
                                                </CombinedGeometry.Geometry1>
                                                <CombinedGeometry.Geometry2>
                                                    <EllipseGeometry Center="270,270" RadiusX="220" RadiusY="220" />
                                                </CombinedGeometry.Geometry2>
                                            </CombinedGeometry>
                                        </Path.Data>
                                    </Path>

                                    <!-- Eyepiece border ring -->
                                    <Ellipse Width="440" Height="440" Stroke="#40818CF8" StrokeThickness="2.0" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCoAligning}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>

                                    <!-- 3. Futuristic Augmented Reality HUD Radar Overlay (0.85 opacity) -->
                                    <Canvas Width="500" Height="500" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False" MouseLeftButtonDown="RadarCanvas_MouseLeftButtonDown" MouseMove="RadarCanvas_MouseMove" Cursor="Hand" Opacity="0.85">
                                        <Canvas.Style>
                                            <Style TargetType="Canvas">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="IsHitTestVisible" Value="True" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRadarOverlayEnabled}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsCoAligning}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Setter Property="IsHitTestVisible" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Canvas.Style>

                                        <!-- Concentric HUD Rings -->
                                        <Ellipse Canvas.Left="30" Canvas.Top="30" Width="440" Height="440" Stroke="#FF818CF8" StrokeThickness="1.2" />
                                        <Ellipse Canvas.Left="103.33" Canvas.Top="103.33" Width="293.33" Height="293.33" Stroke="#A0818CF8" StrokeThickness="0.8" StrokeDashArray="4,4" />
                                        <Ellipse Canvas.Left="176.67" Canvas.Top="176.67" Width="146.67" Height="146.67" Stroke="#A0818CF8" StrokeThickness="0.8" StrokeDashArray="4,4" />
                                        <Ellipse Canvas.Left="237.78" Canvas.Top="237.78" Width="24.44" Height="24.44" Stroke="#A0EF4444" StrokeThickness="0.8" StrokeDashArray="2,2" />
                                        <Ellipse Canvas.Left="248" Canvas.Top="248" Width="4" Height="4" Fill="#FF818CF8" />

                                        <!-- Radial Azimuth lines -->
                                        <Line X1="250" Y1="30" X2="250" Y2="470" Stroke="#FF818CF8" StrokeThickness="0.8" />
                                        <Line X1="30" Y1="250" X2="470" Y2="250" Stroke="#FF818CF8" StrokeThickness="0.8" />

                                        <!-- Cardinal Labels -->
                                        <TextBlock Text="N" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="245" Canvas.Top="10" />
                                        <TextBlock Text="S" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="245" Canvas.Top="475" />
                                        <TextBlock Text="E" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="475" Canvas.Top="242" />
                                        <TextBlock Text="W" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="12" Canvas.Top="242" />

                                        <!-- Horizon Obstacle Shaded Zone -->
                                        <Polygon Points="{Binding RadarObstructionPoints}" Fill="#3000F3FF" IsHitTestVisible="False" />

                                        <!-- Horizon Obstacle Trace Line -->
                                        <Polyline Points="{Binding RadarHorizonPoints}" Stroke="#FF00F3FF" StrokeThickness="2.0" StrokeLineJoin="Round" IsHitTestVisible="False" />

                                        <!-- Dropped Pins Nodes -->
                                        <ItemsControl ItemsSource="{Binding HorizonNodes}" IsHitTestVisible="False">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="500" Height="500" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding RadarX}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding RadarY}" />
                                                    <Setter Property="Margin" Value="-3,-3,0,0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="6" Height="6" Fill="#FFF59E0B" Stroke="#FF0c0c0e" StrokeThickness="1.0" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Mount Slew Crosshair -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMountConnected}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="20" Height="20" Margin="-10,-10,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="TelescopeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="TelescopeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="14" Height="14" Stroke="#EF4444" StrokeThickness="1.2" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="3" Height="3" Fill="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Line X1="0" Y1="10" X2="20" Y2="10" Stroke="#EF4444" StrokeThickness="0.8" />
                                                <Line X1="10" Y1="0" X2="10" Y2="20" Stroke="#EF4444" StrokeThickness="0.8" />
                                            </Grid>
                                        </Canvas>

                                        <!-- Active Selected Node Reticle -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActiveNode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="16" Height="16" Margin="-8,-8,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="ActiveNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="ActiveNodeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="12" Height="12" Stroke="#FF00F3FF" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="3" Height="3" Fill="#FF00F3FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Canvas>

                                        <!-- Special Sync Node Landmark (🔷) -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSpecialSyncNode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="12" Height="12" Margin="-6,-6,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="SpecialSyncNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="SpecialSyncNodeRadarY" />
                                                </Canvas.Top>
                                                <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#FFD946EF" Stroke="#FF0c0c0e" StrokeThickness="1.0" ToolTip="Special Sync Node (Landmark)" />
                                            </Grid>
                                        </Canvas>

                                        <!-- Profile Sync Reference Target Overlay -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="24" Height="24" Margin="-12,-12,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="ActiveNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="ActiveNodeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="20" Height="20" Stroke="#C08B5CF6" StrokeThickness="2.0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="8" Height="8" Fill="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Canvas>
                                    </Canvas>
                                </Grid>
                            </Viewbox>
                            </Grid>
                        </Border>
                    </TabItem>

                    <!-- Tab 2: Sky Dome Radar -->
                    <TabItem Header="🌐 Sky Dome Radar">
                        <Grid Background="#0c0c0e" MinWidth="320" MinHeight="320">
                            <!-- Sky Dome Radar Canvas Container (Auto-scaling inside a Viewbox) -->
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10">
                                    <Grid Width="540" Height="540">
                                    <!-- Radial Sky Grid Canvas -->
                                    <Canvas Width="500" Height="500" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="False" MouseLeftButtonDown="RadarCanvas_MouseLeftButtonDown" MouseMove="RadarCanvas_MouseMove" Cursor="Hand">
                                        <!-- Concentric Grid Circles -->
                                        <!-- Horizon (0°) -->
                                        <Ellipse Canvas.Left="30" Canvas.Top="30" Width="440" Height="440" Stroke="#30818CF8" StrokeThickness="1.5" />
                                        <!-- 30° Altitude -->
                                        <Ellipse Canvas.Left="103.33" Canvas.Top="103.33" Width="293.33" Height="293.33" Stroke="#15818CF8" StrokeThickness="1" StrokeDashArray="4,4" />
                                        <!-- 60° Altitude -->
                                        <Ellipse Canvas.Left="176.67" Canvas.Top="176.67" Width="146.67" Height="146.67" Stroke="#15818CF8" StrokeThickness="1" StrokeDashArray="4,4" />
                                        <!-- 85° Zenith Safety Limit -->
                                        <Ellipse Canvas.Left="237.78" Canvas.Top="237.78" Width="24.44" Height="24.44" Stroke="#30EF4444" StrokeThickness="1.0" StrokeDashArray="2,2" />
                                        <!-- Center (Zenith 90°) -->
                                        <Ellipse Canvas.Left="248" Canvas.Top="248" Width="4" Height="4" Fill="#60818CF8" />

                                        <!-- Altitude Labels -->
                                        <TextBlock Text="30°" FontSize="8" Foreground="#50818CF8" Canvas.Left="252" Canvas.Top="106" />
                                        <TextBlock Text="60°" FontSize="8" Foreground="#50818CF8" Canvas.Left="252" Canvas.Top="179" />
                                        <TextBlock Text="85°" FontSize="8" Foreground="#50EF4444" Canvas.Left="252" Canvas.Top="231" />

                                        <!-- Radial Azimuth lines -->
                                        <Line X1="250" Y1="30" X2="250" Y2="470" Stroke="#15818CF8" StrokeThickness="1" />
                                        <Line X1="30" Y1="250" X2="470" Y2="250" Stroke="#15818CF8" StrokeThickness="1" />
                                        <Line X1="94.44" Y1="94.44" X2="405.56" Y2="405.56" Stroke="#08818CF8" StrokeThickness="1" StrokeDashArray="3,3" />
                                        <Line X1="94.44" Y1="405.56" X2="405.56" Y2="94.44" Stroke="#08818CF8" StrokeThickness="1" StrokeDashArray="3,3" />

                                        <!-- Azimuth Cardinal Labels -->
                                        <TextBlock Text="N / 0°" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="230" Canvas.Top="8" />
                                        <TextBlock Text="S / 180°" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="225" Canvas.Top="475" />
                                        <TextBlock Text="E / 90°" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="475" Canvas.Top="242" />
                                        <TextBlock Text="W / 270°" FontSize="9.5" FontWeight="Bold" Foreground="#FFF59E0B" Canvas.Left="0" Canvas.Top="242" />

                                        <TextBlock Text="45°" FontSize="8.5" Foreground="Gray" Canvas.Left="410" Canvas.Top="72" />
                                        <TextBlock Text="135°" FontSize="8.5" Foreground="Gray" Canvas.Left="410" Canvas.Top="410" />
                                        <TextBlock Text="225°" FontSize="8.5" Foreground="Gray" Canvas.Left="72" Canvas.Top="410" />
                                        <TextBlock Text="315°" FontSize="8.5" Foreground="Gray" Canvas.Left="72" Canvas.Top="72" />

                                        <!-- 1a. Horizon Obstacle Shaded Zone -->
                                        <Polygon Points="{Binding RadarObstructionPoints}" Fill="#1E00F3FF" IsHitTestVisible="False" />

                                        <!-- 1b. Horizon Obstacle Trace Line -->
                                        <Polyline Points="{Binding RadarHorizonPoints}" Stroke="#FF00F3FF" StrokeThickness="2.5" StrokeLineJoin="Round" Opacity="0.85" />

                                        <!-- 2. Interactive Dropped Pins Nodes -->
                                        <ItemsControl ItemsSource="{Binding HorizonNodes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <Canvas Width="500" Height="500" IsHitTestVisible="False" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemContainerStyle>
                                                <Style TargetType="ContentPresenter">
                                                    <Setter Property="Canvas.Left" Value="{Binding RadarX}" />
                                                    <Setter Property="Canvas.Top" Value="{Binding RadarY}" />
                                                    <Setter Property="Margin" Value="-4,-4,0,0" />
                                                </Style>
                                            </ItemsControl.ItemContainerStyle>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Ellipse Width="8" Height="8" Fill="#FFF59E0B" Stroke="#FF0c0c0e" StrokeThickness="1.5" ToolTip="{Binding}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- 3. Dynamic Mount Slew Crosshair -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMountConnected}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="24" Height="24" Margin="-12,-12,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="TelescopeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="TelescopeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="18" Height="18" Stroke="#EF4444" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="4" Height="4" Fill="#EF4444" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Line X1="0" Y1="12" X2="24" Y2="12" Stroke="#EF4444" StrokeThickness="1.0" />
                                                <Line X1="12" Y1="0" X2="12" Y2="24" Stroke="#EF4444" StrokeThickness="1.0" />
                                            </Grid>
                                        </Canvas>

                                        <!-- 4. Active/Selected Node Indicator -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasActiveNode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="20" Height="20" Margin="-10,-10,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="ActiveNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="ActiveNodeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="16" Height="16" Stroke="#FF00F3FF" StrokeThickness="2.0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="4" Height="4" Fill="#FF00F3FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Canvas>

                                        <!-- Special Sync Node Landmark (🔷) -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSpecialSyncNode}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="12" Height="12" Margin="-6,-6,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="SpecialSyncNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="SpecialSyncNodeRadarY" />
                                                </Canvas.Top>
                                                <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#FFD946EF" Stroke="#FF0c0c0e" StrokeThickness="1.0" ToolTip="Special Sync Node (Landmark)" />
                                            </Grid>
                                        </Canvas>

                                        <!-- Profile Sync Reference Target Overlay -->
                                        <Canvas IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Grid Width="24" Height="24" Margin="-12,-12,0,0">
                                                <Canvas.Left>
                                                    <Binding Path="ActiveNodeRadarX" />
                                                </Canvas.Left>
                                                <Canvas.Top>
                                                    <Binding Path="ActiveNodeRadarY" />
                                                </Canvas.Top>
                                                <Ellipse Width="20" Height="20" Stroke="#C08B5CF6" StrokeThickness="2.0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Ellipse Width="8" Height="8" Fill="#8B5CF6" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Canvas>
                                    </Canvas>
                                </Grid>
                            </Viewbox>

                            <!-- Shaded Legend Card in the Corner -->
                            <Border CornerRadius="4" Background="#1A1A22" BorderThickness="1" BorderBrush="#2D2D38" Padding="8,6" Margin="10" VerticalAlignment="Bottom" HorizontalAlignment="Left" Opacity="0.8">
                                <StackPanel Orientation="Vertical">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Border Width="12" Height="8" CornerRadius="1" BorderBrush="#FF00F3FF" BorderThickness="1.5" Background="#1E00F3FF" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Text="Horizon Obstruction Zone" FontSize="8.5" Foreground="DarkGray" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="6" Height="6" Fill="#FFF59E0B" VerticalAlignment="Center" Margin="3,0,9,0" />
                                        <TextBlock Text="Horizon Nodes (Pins)" FontSize="8.5" Foreground="DarkGray" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Ellipse Width="6" Height="6" Stroke="#EF4444" StrokeThickness="1.5" VerticalAlignment="Center" Margin="3,0,9,0" />
                                        <TextBlock Text="Telescope Pointer (Active)" FontSize="8.5" Foreground="DarkGray" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Stroke="#FF00F3FF" StrokeThickness="1.5" VerticalAlignment="Center" Margin="3,0,9,0" />
                                        <TextBlock Text="Active Verification Node" FontSize="8.5" Foreground="DarkGray" VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>

                <!-- Column 1: Action center & Setting feeds -->
                <Border Grid.Column="1" CornerRadius="8" Background="{DynamicResource MahApps.Brushes.Subtle}" Padding="12" BorderThickness="1" BorderBrush="#2A2A30">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- UVC Webcam Configuration (Row 0) -->
                                <RowDefinition Height="Auto" /> <!-- Webcam Co-Alignment Assistant (Row 1) -->
                                <RowDefinition Height="Auto" /> <!-- Main Active Mapping Controls (Row 2) -->
                                <RowDefinition Height="Auto" /> <!-- Point Verification Panel (Row 3) -->
                                <RowDefinition Height="Auto" /> <!-- Virtual Alt-Az Jogging Panel (Row 4) -->
                                <RowDefinition Height="Auto" /> <!-- Hardware Parameters & Safety Checklist (Row 5) -->
                                <RowDefinition Height="*" MinHeight="100" /> <!-- Console logs (Row 6) -->
                            </Grid.RowDefinitions>
                            <Grid.Resources>
                                <Style x:Key="ActionBtnStyle" TargetType="Button">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <Grid>
                                                        <Border x:Name="glow" Background="White" Opacity="0" CornerRadius="6" />
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="glow" Property="Opacity" Value="0.15" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#353540" />
                                                        <Setter Property="Cursor" Value="Arrow" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <!-- Row 0: UVC Webcam Configuration -->
                            <Border Grid.Row="0" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
                                <StackPanel Orientation="Vertical">
                                    <!-- Webcam Header with Dot Status Indicator -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="UVC Webcam Configuration" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" VerticalAlignment="Center" />
                                        
                                        <!-- Webcam State Status Badge -->
                                        <Border Grid.Column="1" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="6,2" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="{Binding WebcamStatusIndicatorColor}" Margin="0,0,5,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding CurrentWebcamState}" FontSize="9.5" FontWeight="SemiBold" Foreground="{Binding WebcamStatusIndicatorColor}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <!-- Camera Chooser Dropdown and Refresh Button -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Grid.Column="0" ItemsSource="{Binding AvailableWebcams}" SelectedItem="{Binding SelectedWebcam}" Height="28" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" VerticalContentAlignment="Center">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" Foreground="White" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                        <Button Grid.Column="1" Command="{Binding RefreshWebcamsCommand}" Content="🔄" Width="28" Height="28" Margin="6,0,0,0" ToolTip="Refresh available webcams list" Background="#2A2A35" Foreground="White" FontWeight="Bold" Cursor="Hand" />
                                    </Grid>

                                    <!-- Start / Stop Stream Actions -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start Video Feed" Command="{Binding StartWebcamCommand}" Height="28" Background="#6366F1" Margin="0,0,4,0" FontSize="11" />
                                        <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Stop Video Feed" Command="{Binding StopWebcamCommand}" Height="28" Background="#EF4444" Margin="4,0,0,0" FontSize="11" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Row 1: Webcam Co-Alignment Assistant -->
                            <Border Grid.Row="1" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Webcam Co-Alignment Assistant" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                                    
                                    <!-- Co-Alignment Instruction Tip -->
                                    <Border CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="8" Margin="0,0,0,8">
                                        <TextBlock Text="Align the webcam feed with your primary telescope axis. Center a target in your main camera, click the same target in the webcam view, and save." FontSize="9.5" Foreground="DarkGray" TextWrapping="Wrap" />
                                    </Border>
                                    
                                    <!-- Co-Alignment Status Badge and Target Center readout -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Center Ratio: " FontSize="9.5" Foreground="Gray" />
                                            <TextBlock Text="{Binding AlignmentCenterX, StringFormat={}{0:F3}}" FontSize="9.5" FontWeight="SemiBold" Foreground="#FFF59E0B" />
                                            <TextBlock Text=", " FontSize="9.5" Foreground="Gray" />
                                            <TextBlock Text="{Binding AlignmentCenterY, StringFormat={}{0:F3}}" FontSize="9.5" FontWeight="SemiBold" Foreground="#FFF59E0B" />
                                        </StackPanel>
                                        
                                        <Border Grid.Column="1" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="6,2" VerticalAlignment="Center">
                                            <TextBlock Text="ALIGNED" FontSize="8.5" FontWeight="Bold" Foreground="#22C55E" VerticalAlignment="Center" Visibility="{Binding IsCoAligned, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        </Border>
                                    </Grid>

                                    <!-- Co-Alignment Buttons -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start" Command="{Binding StartCoAlignmentCommand}" Height="28" Background="#8B5CF6" Margin="0,0,4,0" FontSize="11" ToolTip="Start Co-Alignment assistant" />
                                        <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Save" Command="{Binding SaveCoAlignmentCommand}" IsEnabled="{Binding IsCoAligning}" Height="28" Background="#22C55E" Margin="4,0,4,0" FontSize="11" ToolTip="Save co-alignment coordinate" />
                                        <Button Grid.Column="2" Style="{StaticResource ActionBtnStyle}" Content="Reset" Command="{Binding ResetCoAlignmentCommand}" Height="28" Background="#E11D48" Margin="4,0,0,0" FontSize="11" ToolTip="Reset co-alignment to center" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Row 2: Main Active Mapping Controls -->
                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Placed Node interactions -->
                                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ActionBtnStyle}" Content="Drop Horizon Pin [Spacebar]" Command="{Binding DropPinCommand}" Height="36" IsEnabled="{Binding CanDropPin}" Background="#3B82F6" Margin="0,0,0,6" />
                                
                                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Remove Current Pin" Command="{Binding DeletePointCommand}" Height="28" Background="#6B7280" Margin="0,0,4,6" FontSize="11" ToolTip="Remove the currently selected pin" />
                                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Clear All Pins" Command="{Binding ClearPinsCommand}" Height="28" Background="#E11D48" Margin="4,0,0,6" FontSize="11" ToolTip="Remove all horizon pins" />

                                <!-- Save & Load Horizon Profile -->
                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Save Horizon Profile" Command="{Binding SaveHorizonCommand}" Height="34" Background="#F59E0B" Margin="0,0,4,0" ToolTip="Save the collected pins to a N.I.N.A. .hrzn file" />
                                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Load Horizon Profile" Command="{Binding LoadHorizonCommand}" Height="34" Background="#10B981" Margin="4,0,0,0" ToolTip="Load a N.I.N.A. .hrzn profile" />
                                </Grid>
                            </Grid>

                            <!-- Row 3: Point Verification Panel -->
                            <Border Grid.Row="3" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,0,12">
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Text="Point Verification (Slew Back)" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,8" />
                                    
                                    <Border CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="8" Margin="0,0,0,8">
                                        <TextBlock Text="Select a node and slew the mount back to physically verify your mapped points." FontSize="9.5" Foreground="DarkGray" TextWrapping="Wrap" />
                                    </Border>
                                    
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="◀ Slew CCW" Command="{Binding SlewCCWCommand}" IsEnabled="{Binding CanVerifyPoints}" Height="28" Background="#4F46E5" Margin="0,0,4,8" FontSize="11" ToolTip="Slew Counter-Clockwise (Decreasing Azimuth)" />
                                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Slew CW ▶" Command="{Binding SlewCWCommand}" IsEnabled="{Binding CanVerifyPoints}" Height="28" Background="#4F46E5" Margin="4,0,0,8" FontSize="11" ToolTip="Slew Clockwise (Increasing Azimuth)" />

                                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="Verification Step Size:  " FontSize="11" Foreground="Gray" VerticalAlignment="Center" />
                                            <ComboBox ItemsSource="{Binding VerificationStepSizes}" SelectedItem="{Binding VerificationStepSize}" Width="70" Height="26" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Special Sync Landmark Card -->
                                    <!-- Special Sync Landmark Card -->
                                    <Border CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="#2D2D35" Padding="8,6" Margin="0,8,0,0">
                                        <StackPanel Orientation="Vertical">
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="🔷 SPECIAL SYNC LANDMARK" FontSize="10" FontWeight="SemiBold" Foreground="#FFD946EF" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Command="{Binding ClearSpecialSyncNodeCommand}" Content="❌ Clear" Height="18" Background="#EF4444" Foreground="White" FontSize="9" Padding="6,0" Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasSpecialSyncNode}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>

                                            <!-- If NOT defined, show button to set -->
                                            <StackPanel Orientation="Vertical">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSpecialSyncNode}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource ActionBtnStyle}" Content="Set Mount as Landmark" Command="{Binding SetSpecialSyncNodeCommand}" Height="24" Background="#8B5CF6" Margin="0,2,0,0" FontSize="10" ToolTip="Save current telescope coordinates as the Special Sync landmark" />
                                            </StackPanel>

                                            <!-- If defined, show coordinates and action buttons -->
                                            <StackPanel Orientation="Vertical">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSpecialSyncNode}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                                                    <TextBlock Text="Az: " FontSize="11" Foreground="DarkGray" />
                                                    <TextBlock Text="{Binding SpecialSyncNode.Azimuth, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FFD946EF" />
                                                    <TextBlock Text="  Alt: " FontSize="11" Foreground="DarkGray" />
                                                    <TextBlock Text="{Binding SpecialSyncNode.Altitude, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FFD946EF" />
                                                </StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="🔷 Slew" Command="{Binding SlewToSpecialSyncNodeCommand}" Height="24" Background="#4F46E5" Margin="0,0,3,0" FontSize="10" ToolTip="Slew mount directly to this landmark" />
                                                    <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="🔷 Select Landmark" Command="{Binding SelectSpecialSyncNodeCommand}" Height="24" Background="#8B5CF6" Margin="3,0,0,0" FontSize="10" ToolTip="Select this landmark as the active target" />
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Active Selected Node Details & Sync Operations -->
                                    <Border CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="#2D2D35" Padding="8,6" Margin="0,8,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasActiveNode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSpecialSyncNodeSelected}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Vertical">
                                                <!-- Title: standard active node or sync node -->
                                                <TextBlock FontSize="10" Foreground="Gray" Text="ACTIVE VERIFICATION NODE" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSpecialSyncNodeSelected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="#FFD946EF" Text="ACTIVE SYNC LANDMARK" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSpecialSyncNodeSelected}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="#FF818CF8" Text="PROFILE SYNC REFERENCE NODE" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>

                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <!-- Standard Index Panel -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSpecialSyncNodeSelected}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="Index: " FontSize="11" Foreground="DarkGray" />
                                                        <TextBlock Text="{Binding ActiveNodeIndex}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF" />
                                                        <TextBlock Text="  |  " FontSize="11" Foreground="DarkGray" />
                                                    </StackPanel>
                                                    
                                                    <!-- Special Sync Node Landmark Panel -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSpecialSyncNodeSelected}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="Landmark  |  " FontSize="11" FontWeight="Bold" Foreground="#FFD946EF" />
                                                    </StackPanel>

                                                    <TextBlock Text="Az: " FontSize="11" Foreground="DarkGray" />
                                                    <TextBlock Text="{Binding SyncRefNode.Azimuth, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ActiveNode.Azimuth, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="  Alt: " FontSize="11" Foreground="DarkGray" />
                                                    <TextBlock Text="{Binding SyncRefNode.Altitude, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ActiveNode.Altitude, StringFormat={}{0:F2}°}" FontSize="11" FontWeight="Bold" Foreground="#FF00F3FF">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Standard Card Buttons (Prepare Sync, Delete Node) -->
                                                <StackPanel Orientation="Vertical">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Prepare Sync" Command="{Binding PrepareSyncCommand}" Height="24" Background="#8B5CF6" Margin="0,0,4,0" FontSize="10.5" ToolTip="Prepare 3D Tilt Correction Sync for this node" />
                                                        <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Delete Node" Command="{Binding DeletePointCommand}" Height="24" Background="#EF4444" Margin="4,0,0,0" FontSize="10.5" ToolTip="Remove this node from active session" />
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Sync-Prep Card Buttons (Confirm Sync, Cancel Sync) -->
                                                <StackPanel Orientation="Vertical">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSyncPreparing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    
                                                    <!-- Warning/Instruction Banner -->
                                                    <Border CornerRadius="4" Background="#1E1B4B" BorderThickness="1" BorderBrush="#4338CA" Padding="6,4" Margin="0,6,0,0">
                                                        <TextBlock Text="{Binding SyncInstructionText}" FontSize="9.5" FontWeight="SemiBold" Foreground="#FFE0E7FF" TextWrapping="Wrap" />
                                                    </Border>
                                                    
                                                    <Grid Margin="0,6,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Confirm Sync" Command="{Binding ConfirmSyncCommand}" Height="24" Background="#10B981" Margin="0,0,4,0" FontSize="10.5" ToolTip="Confirm 3D Tilt Correction (Mount must be jogged/moved from original target coordinates first)" />
                                                        <Button Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Cancel" Command="{Binding CancelSyncCommand}" Height="24" Background="#6B7280" Margin="4,0,0,0" FontSize="10.5" ToolTip="Abort the synchronization process" />
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Row 4: Virtual Alt-Az Jogging Panel (5x5 Grid) -->
                            <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,0,0,12">
                                <TextBlock Text="Virtual Alt-Az Jogging" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,6" />
                                
                                <Grid Width="180" Height="150" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Row 0: Double-Arrow Diagonals & North -->
                                    <Button Grid.Row="0" Grid.Column="0" Content="↖↖" Command="{Binding DoubleJogNorthWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt+, Az-" FontSize="9" />
                                    <Button Grid.Row="0" Grid.Column="1" Content="▲▲◀" Command="{Binding JogN2W1Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt Up, Single Az Left" FontSize="9" />
                                    <Button Grid.Row="0" Grid.Column="2" Content="▲▲" Command="{Binding DoubleJogNorthCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Double Alt+" FontSize="9" />
                                    <Button Grid.Row="0" Grid.Column="3" Content="▲▲▶" Command="{Binding JogN2E1Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt Up, Single Az Right" FontSize="9" />
                                    <Button Grid.Row="0" Grid.Column="4" Content="↗↗" Command="{Binding DoubleJogNorthEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt+, Az+" FontSize="9" />

                                    <!-- Row 1: Single-Arrow Diagonals & North -->
                                    <Button Grid.Row="1" Grid.Column="0" Content="▲◀◀" Command="{Binding JogN1W2Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Single Alt Up, Double Az Left" FontSize="9" />
                                    <Button Grid.Row="1" Grid.Column="1" Content="↖" Command="{Binding JogNorthWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az-" />
                                    <Button Grid.Row="1" Grid.Column="2" Content="▲" Command="{Binding JogNorthCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Alt+" />
                                    <Button Grid.Row="1" Grid.Column="3" Content="↗" Command="{Binding JogNorthEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt+, Az+" />
                                    <Button Grid.Row="1" Grid.Column="4" Content="▲▶▶" Command="{Binding JogN1E2Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Single Alt Up, Double Az Right" FontSize="9" />

                                    <!-- Row 2: Double/Single West, Home, Single/Double East -->
                                    <Button Grid.Row="2" Grid.Column="0" Content="◀◀" Command="{Binding DoubleJogWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Double Az-" FontSize="9" />
                                    <Button Grid.Row="2" Grid.Column="1" Content="◀" Command="{Binding JogWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Az-" />
                                    <Button Grid.Row="2" Grid.Column="2" Content="⌂" Command="{Binding HomeMountCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2563EB" ToolTip="Home Mount" FontSize="14" />
                                    <Button Grid.Row="2" Grid.Column="3" Content="▶" Command="{Binding JogEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Az+" />
                                    <Button Grid.Row="2" Grid.Column="4" Content="▶▶" Command="{Binding DoubleJogEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Double Az+" FontSize="9" />

                                    <!-- Row 3: Single-Arrow Diagonals & South -->
                                    <Button Grid.Row="3" Grid.Column="0" Content="▼◀◀" Command="{Binding JogS1W2Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Single Alt Down, Double Az Left" FontSize="9" />
                                    <Button Grid.Row="3" Grid.Column="1" Content="↙" Command="{Binding JogSouthWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az-" />
                                    <Button Grid.Row="3" Grid.Column="2" Content="▼" Command="{Binding JogSouthCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" ToolTip="Alt-" />
                                    <Button Grid.Row="3" Grid.Column="3" Content="↘" Command="{Binding JogSouthEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Alt-, Az+" />
                                    <Button Grid.Row="3" Grid.Column="4" Content="▼▶▶" Command="{Binding JogS1E2Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#374151" ToolTip="Single Alt Down, Double Az Right" FontSize="9" />

                                    <!-- Row 4: Double-Arrow Diagonals & South -->
                                    <Button Grid.Row="4" Grid.Column="0" Content="↙↙" Command="{Binding DoubleJogSouthWestCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt-, Az-" FontSize="9" />
                                    <Button Grid.Row="4" Grid.Column="1" Content="▼▼◀" Command="{Binding JogS2W1Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt Down, Single Az Left" FontSize="9" />
                                    <Button Grid.Row="4" Grid.Column="2" Content="▼▼" Command="{Binding DoubleJogSouthCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#3A4350" ToolTip="Double Alt-" FontSize="9" />
                                    <Button Grid.Row="4" Grid.Column="3" Content="▼▼▶" Command="{Binding JogS2E1Command}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt Down, Single Az Right" FontSize="9" />
                                    <Button Grid.Row="4" Grid.Column="4" Content="↘↘" Command="{Binding DoubleJogSouthEastCommand}" IsEnabled="{Binding CanJog}" Style="{StaticResource ActionBtnStyle}" Background="#2B303C" ToolTip="Double Alt-, Az+" FontSize="9" />
                                </Grid>

                                <!-- Emergency Stop Button -->
                                <Button Command="{Binding StopMountCommand}" IsEnabled="{Binding IsMountConnected}" Style="{StaticResource ActionBtnStyle}" Background="#EF4444" Height="28" Margin="0,8,0,0" ToolTip="EMERGENCY JOG SLEW STOP">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🛑" Margin="0,0,6,0" VerticalAlignment="Center" />
                                        <TextBlock Text="EMERGENCY STOP" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Row 5: Hardware Parameters & Safety Checklist -->
                            <Grid Grid.Row="5" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Manual step sizes -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                                    <TextBlock Text="↕ Jog Step Alt (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding StepSizeAlt, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,6">
                                    <TextBlock Text="↔ Jog Step Az (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding StepSizeAz, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                                </StackPanel>

                                <!-- Camera Rotation & Offset -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="4,0,0,6" ToolTip="Counter-rotates the webcam view for EQ mounts. Use offset to level the horizon.">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="🔄 EQ Auto-Rotate" FontSize="9" Foreground="DarkGray" Margin="0,0,4,0" VerticalAlignment="Center" />
                                        <CheckBox IsChecked="{Binding IsCounterRotationEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Slider Value="{Binding CameraRotationOffset, UpdateSourceTrigger=PropertyChanged}" Minimum="-180" Maximum="180" TickFrequency="1" IsSnapToTickEnabled="True" Height="20" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CameraRotationOffset, StringFormat=Offset: {0}°}" FontSize="9" Foreground="DarkGray" HorizontalAlignment="Center" />
                                </StackPanel>

                                <!-- Safety exclusions checklist -->
                                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,6" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" ToolTip="Enables/disables the 15° Solar proximity lockout.">
                                        <TextBlock Text="Solar Safety" Foreground="#FBBF24" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <CheckBox IsChecked="{Binding EnableSolarSafety, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" ToolTip="Enables/disables the 85° Zenith proximity lockout.">
                                        <TextBlock Text="Zenith Lock" Foreground="#FCA5A5" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <CheckBox IsChecked="{Binding EnableZenithSafety, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" ToolTip="Locks altitude to Horizon only (Azimuth sweeps).">
                                        <TextBlock Text="Horiz. Lock" Foreground="#818CF8" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <CheckBox IsChecked="{Binding HorizonLockEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,12,4" ToolTip="Iteratively slews to counter sidereal drift and land exactly on target (Micro-Jump).">
                                        <TextBlock Text="🎯 Exact Pos." Foreground="#34D399" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <CheckBox IsChecked="{Binding IsExactPositionEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" ToolTip="Superimposes the transparent Sky Dome Radar grid over the Live webcam feed.">
                                        <TextBlock Text="📡 HUD Overlay" Foreground="#FFA07A" FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0" />
                                        <CheckBox IsChecked="{Binding IsRadarOverlayEnabled, UpdateSourceTrigger=PropertyChanged}" Cursor="Hand" VerticalAlignment="Center" />
                                    </StackPanel>
                                </WrapPanel>

                                <!-- Field rotation angle readout -->
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="4,4,0,6" ToolTip="Calculated Field Rotation Angle (Parallactic Angle)">
                                    <TextBlock Text="Rot. Angle" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <Border CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Height="24" Padding="6,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding WebcamImageRotationAngle, StringFormat={}{0:F1}°}" FontSize="10" FontWeight="Bold" Foreground="#FF00F3FF" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- Row 6: Log console feeds -->
                            <Border Grid.Row="6" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="8" Margin="0,4,0,4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="System Activity Logs" FontSize="9" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding Logs}" FontSize="9.5" Foreground="#9AFF9A" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 3. Bottom Row: Card indicators -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Mount Position Alt-Az -->
                <Border Grid.Column="0" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="MOUNT POSITION (ALT/AZ)" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CurrentAlt, StringFormat={}{0:F2}°}" FontSize="15" FontWeight="Bold" Foreground="#72BDFF" />
                            <TextBlock Text=" / " FontSize="15" Foreground="Gray" />
                            <TextBlock Text="{Binding CurrentAz, StringFormat={}{0:F2}°}" FontSize="15" FontWeight="Bold" Foreground="#72BDFF" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Last Pin Placed -->
                <Border Grid.Column="1" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="LAST PIN PLACED" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding LastNodeText}" FontSize="15" FontWeight="Bold" Foreground="#FFE79A" Margin="0,4,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Node Count Placed -->
                <Border Grid.Column="2" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL NODES PLACED" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding NodeCount}" FontSize="15" FontWeight="Bold" Foreground="#22C55E" Margin="0,4,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
