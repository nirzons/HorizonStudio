<ResourceDictionary
    x:Class="NirZonshine.NINA.HorizonVisualMapper.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:local="clr-namespace:NirZonshine.NINA.HorizonVisualMapper"
    xmlns:vm="clr-namespace:NirZonshine.NINA.HorizonVisualMapper.ViewModels">

    <!-- Global HVM Options DataTemplate -->
    <DataTemplate x:Key="Horizon Visual Mapper_Options">
        <StackPanel Orientation="Vertical" Margin="10">
            <TextBlock Text="Horizon Visual Mapper Settings" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,10" />
            <TextBlock Text="No global configuration is required. All settings can be adjusted directly from the Horizon Visual Mapper panel in the Imaging screen." Foreground="#999" TextWrapping="Wrap" />
        </StackPanel>
    </DataTemplate>

    <!-- Main Dockable UI DataTemplate (Loaded in N.I.N.A Imaging Screen) -->
    <DataTemplate x:Key="NirZonshine.NINA.HorizonVisualMapper.ViewModels.HorizonMapperDockableVM_Dockable">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. Header & Status Banner Row -->
            <StackPanel Grid.Row="0" Orientation="Vertical">
                <Border CornerRadius="8" Background="{DynamicResource MahApps.Brushes.Subtle}" Padding="15" Margin="0,0,0,8" BorderThickness="1" BorderBrush="{DynamicResource MahApps.Brushes.Accent}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="Horizon Visual Mapper (HVM)" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" />
                            <TextBlock Text="Trace terrestrial obstacles in daylight using visual guides to automatically generate custom N.I.N.A. horizon profiles." FontSize="11" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="4" Background="#161b22" BorderThickness="1" BorderBrush="{Binding StatusIndicatorColor}" Padding="8,4" VerticalAlignment="Center">
                            <TextBlock Text="{Binding StatusIndicatorText}" FontWeight="Bold" Foreground="{Binding StatusIndicatorColor}" FontSize="11" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Zenith Proximity Locked Alert Banner -->
                <Border CornerRadius="4" Background="#3D1C1C" BorderThickness="1" BorderBrush="#EF4444" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsZenithSafetyAlert}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🛑" Foreground="#EF4444" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SafetyMessage}" Foreground="#FCA5A5" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Solar Proximity Locked Alert Banner -->
                <Border CornerRadius="4" Background="#3D2A14" BorderThickness="1" BorderBrush="#F59E0B" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSolarSafetyAlert}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" Foreground="#F59E0B" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding SafetyMessage}" Foreground="#FBBF24" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                </Border>

                <!-- Connection Failure Badges -->
                <Border CornerRadius="4" Background="#3A1A1A" BorderThickness="1" BorderBrush="#FF4C4C" Padding="10,6" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMountConnected}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="⚠" Foreground="#FF4C4C" FontSize="14" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="MOUNT NOT CONNECTED - Connect a telescope mount to begin visual horizon mapping" Foreground="#FF8C8C" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 2. Dual-Column Content Row -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" /> <!-- Image Feed & HUD View -->
                    <ColumnDefinition Width="1*" />   <!-- Action & Configuration Controls -->
                </Grid.ColumnDefinitions>

                <!-- Column 0: Camera Live View & Target HUD overlay -->
                <Border Grid.Column="0" CornerRadius="8" Background="#0f0f12" BorderThickness="1" BorderBrush="#2A2A30" Padding="10" Margin="0,0,10,0">
                    <Grid>
                        <!-- Fallback screen if camera is disabled/loading -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Path Data="M4,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4C2.89,20 2,19.1 2,18V6C2,4.89 2.89,4 4,4M4,6V18H20V6H4M11,7A3,3 0 0,1 14,10A3,3 0 0,1 11,13A3,3 0 0,1 8,10A3,3 0 0,1 11,7M18,8A1,1 0 0,1 19,9A1,1 0 0,1 18,10A1,1 0 0,1 17,9A1,1 0 0,1 18,8M5,16H19V17H5V16Z" 
                                  Fill="#3D3D45" Width="48" Height="48" HorizontalAlignment="Center" />
                            <TextBlock Text="UVC Webcam Live Stream" FontSize="13" FontWeight="Bold" Foreground="DarkGray" Margin="0,10,0,2" HorizontalAlignment="Center" />
                            <TextBlock Text="Active UVC webcam frames will display here." FontSize="10" Foreground="Gray" HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Video Stream Source -->
                        <Image Source="{Binding LastFrame}" Stretch="Uniform" />

                        <!-- Concentric Target HUD Overlay -->
                        <Grid IsHitTestVisible="False" Opacity="0.55">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            
                            <!-- Concentric target rings -->
                            <Ellipse Width="180" Height="180" Stroke="#8000FF00" StrokeThickness="0.8" StrokeDashArray="4,4" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="80" Height="80" Stroke="#FF00FF00" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Ellipse Width="8" Height="8" Fill="#FF00FF00" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            
                            <!-- Reticle Lines -->
                            <Rectangle Width="1" Fill="#8000FF00" VerticalAlignment="Stretch" HorizontalAlignment="Center" Margin="0,10" />
                            <Rectangle Height="1" Fill="#8000FF00" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="10,0" />
                        </Grid>
                    </Grid>
                </Border>

                <!-- Column 1: Action center & Setting feeds -->
                <Border Grid.Column="1" CornerRadius="8" Background="{DynamicResource MahApps.Brushes.Subtle}" Padding="12" BorderThickness="1" BorderBrush="#2A2A30">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" /> <!-- Slew buttons -->
                                <RowDefinition Height="Auto" /> <!-- Setup buttons -->
                                <RowDefinition Height="Auto" /> <!-- Parameter details -->
                                <RowDefinition Height="*" MinHeight="100" /> <!-- Console logs -->
                            </Grid.RowDefinitions>
                            <Grid.Resources>
                                <Style x:Key="ActionBtnStyle" TargetType="Button">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                                    <Grid>
                                                        <Border x:Name="glow" Background="White" Opacity="0" CornerRadius="6" />
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="glow" Property="Opacity" Value="0.15" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="border" Property="Background" Value="#353540" />
                                                        <Setter Property="Cursor" Value="Arrow" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <!-- Section 1: Main Active Mapping Controls -->
                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Start and Stop Mapping -->
                                <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Start Mapping Session" Command="{Binding StartMappingCommand}" Height="34" IsEnabled="{Binding CanStart}" Background="#22C55E" Margin="0,0,4,6" />
                                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Stop Session" Command="{Binding StopMappingCommand}" Height="34" IsEnabled="{Binding IsRunning}" Background="#EF4444" Margin="4,0,0,6" />

                                <!-- Placed Node interactions -->
                                <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ActionBtnStyle}" Content="Drop Horizon Pin [Spacebar]" Command="{Binding DropPinCommand}" Height="36" IsEnabled="{Binding IsRunning}" Background="#3B82F6" Margin="0,0,0,6" />
                                
                                <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource ActionBtnStyle}" Content="Undo Last Pin" Command="{Binding UndoPinCommand}" Height="28" IsEnabled="{Binding IsRunning}" Background="#6B7280" Margin="0,0,4,0" FontSize="11" />
                                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource ActionBtnStyle}" Content="Clear All Pins" Command="{Binding ClearPinsCommand}" Height="28" IsEnabled="{Binding IsRunning}" Background="#E11D48" Margin="4,0,0,0" FontSize="11" />
                            </Grid>

                            <!-- Section 2: Virtual Alt-Az Jogging Panel -->
                            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,12">
                                <TextBlock Text="Virtual Alt-Az Jogging" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}" Margin="0,0,0,6" />
                                
                                <Grid Width="160" Height="100" HorizontalAlignment="Center">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Jog Buttons (Up/Down for Alt, Left/Right for Az) -->
                                    <Button Grid.Row="0" Grid.Column="1" Content="▲ Alt+" Command="{Binding JogNorthCommand}" IsEnabled="{Binding IsRunning}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" Padding="6,2" />
                                    <Button Grid.Row="1" Grid.Column="0" Content="◀ Az-" Command="{Binding JogWestCommand}" IsEnabled="{Binding IsRunning}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" Padding="6,2" />
                                    <Button Grid.Row="1" Grid.Column="2" Content="Az+ ▶" Command="{Binding JogEastCommand}" IsEnabled="{Binding IsRunning}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" Padding="6,2" />
                                    <Button Grid.Row="2" Grid.Column="1" Content="▼ Alt-" Command="{Binding JogSouthCommand}" IsEnabled="{Binding IsRunning}" Style="{StaticResource ActionBtnStyle}" Background="#4B5563" Padding="6,2" />
                                    
                                    <!-- Concentric center indicator showing active status -->
                                    <Ellipse Grid.Row="1" Grid.Column="1" Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="Gray" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Fill" Value="#22C55E" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </StackPanel>

                            <!-- Section 3: Hardware Parameters & Safety Checklist -->
                            <Grid Grid.Row="2" Margin="0,0,0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Manual step size -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,4,6">
                                    <TextBlock Text="Jog Step (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding StepSizeManual, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                                </StackPanel>

                                <!-- Backlash Compensation amount -->
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="4,0,4,6">
                                    <TextBlock Text="Backlash (°)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding BacklashCompensationAmount, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                                </StackPanel>

                                <!-- Focal length override -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="4,0,0,6">
                                    <TextBlock Text="Focal L. (mm)" FontSize="9" Foreground="DarkGray" Margin="0,0,0,2" />
                                    <TextBox Text="{Binding FocalLengthOverride, UpdateSourceTrigger=PropertyChanged}" Height="24" VerticalContentAlignment="Center" Background="#1E1E24" BorderBrush="#3D3D45" Foreground="White" Padding="4,0" />
                                </StackPanel>

                                <!-- Safety exclusions checklist -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,4,0,6">
                                    <CheckBox Content="Solar Safety Zone" IsChecked="{Binding EnableSolarSafety, UpdateSourceTrigger=PropertyChanged}" Foreground="#FBBF24" FontSize="9" FontWeight="SemiBold" Margin="0,0,16,0" Cursor="Hand" />
                                    <CheckBox Content="Zenith Lockout" IsChecked="{Binding EnableZenithSafety, UpdateSourceTrigger=PropertyChanged}" Foreground="#FCA5A5" FontSize="9" FontWeight="SemiBold" Margin="0,0,16,0" Cursor="Hand" />
                                    <CheckBox Content="Horizon Lock" IsChecked="{Binding HorizonLockEnabled, UpdateSourceTrigger=PropertyChanged}" Foreground="#818CF8" FontSize="9" FontWeight="SemiBold" Cursor="Hand" />
                                </StackPanel>
                            </Grid>

                            <!-- Section 4: Log console console feeds -->
                            <Border Grid.Row="3" CornerRadius="4" Background="#111115" BorderThickness="1" BorderBrush="#222228" Padding="8" Margin="0,4,0,4">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="System Activity Logs" FontSize="9" FontWeight="Bold" Foreground="Gray" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding Logs}" FontSize="9.5" Foreground="#9AFF9A" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- 3. Bottom Row: Card indicators -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Mount Position Alt-Az -->
                <Border Grid.Column="0" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="MOUNT POSITION (ALT/AZ)" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock Text="{Binding CurrentAlt, StringFormat={}{0:F2}°}" FontSize="15" FontWeight="Bold" Foreground="#72BDFF" />
                            <TextBlock Text=" / " FontSize="15" Foreground="Gray" />
                            <TextBlock Text="{Binding CurrentAz, StringFormat={}{0:F2}°}" FontSize="15" FontWeight="Bold" Foreground="#72BDFF" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Last Pin Placed -->
                <Border Grid.Column="1" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12" Margin="0,0,10,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="LAST PIN PLACED" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding LastNodeText}" FontSize="15" FontWeight="Bold" Foreground="#FFE79A" Margin="0,4,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Node Count Placed -->
                <Border Grid.Column="2" CornerRadius="8" Background="#1A1A20" BorderThickness="1" BorderBrush="#2D2D35" Padding="12">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL NODES PLACED" FontSize="10" Foreground="Gray" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding NodeCount}" FontSize="15" FontWeight="Bold" Foreground="#22C55E" Margin="0,4,0,0" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
